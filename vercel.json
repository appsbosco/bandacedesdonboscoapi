{
  "version": 2,
  "builds": [{ "src": "index.js", "use": "@vercel/node" }],
  "routes": [
    { "src": "/api/graphql", "dest": "index.js" },
    { "src": "/api/cron/(.*)", "dest": "index.js" },
    { "src": "/(.*)", "dest": "/" }
  ],
  "crons": [
    {
      "path": "/api/cron/birthday-notifications",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/attendance-reminders",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/attendance-reminders",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/attendance-reminders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/attendance-reminders",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/attendance-reminders",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/attendance-reminders",
      "schedule": "0 3 * * *"
    }
  ]
}
